# Containerfile.egress — pangolin-egress-proxy
#
# mitmproxy-based egress proxy with two listening ports:
#   3128 tight  — hostname allowlist + Anthropic body inspection +
#                 Authorization injection
#   3129 loose  — any HTTPS host (research-search WebFetch)
#
# All policy lives in src/pangolin/pangolin_egress.py — a mitmproxy addon.
# That single file does Phase A (token hiding via header rewrite) and
# Phase B (server-side-tool body filter).

# Debian-slim base — mitmproxy needs prebuilt wheels for aioquic +
# mitmproxy_rs, which Alpine's musl can't satisfy without a Rust
# toolchain in the build (50× longer build, larger image). Slim Debian
# gets us prebuilt wheels in seconds. Image is ~120MB vs ~50MB if we
# could use Alpine — acceptable for a sidecar proxy.
FROM python:3.12-slim-bookworm@sha256:d97792894a6a4162cae14da44542a83c75e56c77a27b92d58f3f83b7bc961292

RUN pip install --no-cache-dir mitmproxy==11.0.2 \
  && mitmdump --version | head -1

COPY src/pangolin/pangolin_egress.py /usr/local/bin/pangolin_egress.py

# mitmproxy keeps its CA + config under one directory; we point both at
# /etc/mitmproxy so file ownership is predictable. The CA is generated on
# first proxy start; the addon's `running()` hook publishes it to /shared
# for agent containers to mount as NODE_EXTRA_CA_CERTS.
RUN mkdir -p /etc/mitmproxy /shared \
  && chmod 755 /etc/mitmproxy /shared

# Entrypoint: launch mitmdump with two listeners + the addon.
RUN cat > /usr/local/bin/start-proxy.sh <<'EOF'
#!/bin/sh
set -e

if [ -z "$ANTHROPIC_TOKEN" ]; then
    echo "[start-proxy] WARNING: ANTHROPIC_TOKEN empty — Anthropic auth injection disabled"
fi

exec mitmdump \
    --set confdir=/etc/mitmproxy \
    --mode "regular@3128" \
    --mode "regular@3129" \
    -s /usr/local/bin/pangolin_egress.py
EOF

RUN chmod +x /usr/local/bin/start-proxy.sh

EXPOSE 3128 3129
VOLUME /shared

CMD ["/usr/local/bin/start-proxy.sh"]
